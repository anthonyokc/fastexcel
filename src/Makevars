TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libfastexcelr.a
PKG_LIBS = -L$(LIBDIR) -lfastexcelr

all: $(SHLIB)

.PHONY: $(STATLIB)

$(SHLIB): $(STATLIB)

$(STATLIB):
	PATH="$(PATH):$(HOME)/.cargo/bin" cargo build --lib --release --manifest-path=./rust/Cargo.toml --target-dir $(TARGET_DIR)

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) $(TARGET_DIR)
