TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/fastexcelr.lib
PKG_LIBS = -L$(LIBDIR) -lfastexcelr -lws2_32 -ladvapi32 -luserenv -lbcrypt -lntdll

all: $(SHLIB)

.PHONY: $(STATLIB)

$(SHLIB): $(STATLIB)

$(STATLIB):
	PATH="$(PATH);$(USERPROFILE)/.cargo/bin" cargo build --lib --release --manifest-path=./rust/Cargo.toml --target-dir $(TARGET_DIR)

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) $(TARGET_DIR)
